{
  "compilerOptions": {
    "strict": true
  },
  "exclude": [
    ".agents/"
  ],
  "permissions": {
    "default": {
      "net": true,
      "write": true,
      "read": true,
      "env": true
    }
  },
  "tasks": {
    "start": "deno run --env-file -P app.ts",
    "check": "deno check app.ts && deno lint && deno fmt --check",
    "test": "deno test"
  },
  "imports": {
    "@mastra/voice-openai": "npm:@mastra/voice-openai@0.12.2",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/testing/mock": "jsr:@std/testing@^1.0.16",
    "@zod/zod": "npm:zod@^3.25.76",
    "@logtape/logtape": "jsr:@logtape/logtape@^1.1.1",
    "@logtape/pretty": "jsr:@logtape/pretty@^1.1.1",
    "html-to-text": "npm:html-to-text@^9.0.5",
    "unpdf": "npm:unpdf@^0.12.0",
    "@mastra/core": "npm:@mastra/core@1.43.0"
  }
}
